# Demo Mode — runs without Spotify API (true/false)
DEMO_MODE=true

# Spotify API Credentials (required if DEMO_MODE=false)
# Get from: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:5000/callback

# LLM Provider: mimoo, openrouter, or mock (for demo without API key)
LLM_PROVIDER=openrouter

# MiMo API (Xiaomi MiMo Orbit)
# Get from: https://platform.xiaomimimo.com
MIMO_API_KEY=your_mimo_api_key
MIMO_API_URL=https://api.xiaomimimo.com/v1/chat/completions

# OpenRouter (Fallback LLM)
# Get from: https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# Flask
FLASK_SECRET_KEY=your_random_secret_key_here
FLASK_DEBUG=true
